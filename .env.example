# .env.example — Environment variable template for langgraph-agent-stack
#
# Copy this file to .env and fill in real values before starting the application.
#
#   cp .env.example .env
#
# NEVER commit the .env file to source control — it is listed in .gitignore.
# This example file is safe to commit: it contains no real credentials.

# =============================================================================
# LLM PROVIDER SELECTION
# =============================================================================

# Which LLM provider to use.
# Allowed values: anthropic | openai | google | bedrock | azure | ollama | mock
# Default: anthropic
LLM_PROVIDER=anthropic
# LLM_PROVIDER=mock        # No API key needed — deterministic responses for development

# =============================================================================
# ANTHROPIC (Claude) — LLM_PROVIDER=anthropic
# Install: uv sync --extra anthropic
# =============================================================================

ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model identifier. Default: claude-3-5-sonnet-20241022
# Other options: claude-3-haiku-20240307, claude-3-opus-20240229
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# OPENAI (GPT) — LLM_PROVIDER=openai
# Install: uv sync --extra openai
# =============================================================================

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# =============================================================================
# GOOGLE (Gemini) — LLM_PROVIDER=google
# Install: uv sync --extra google
# =============================================================================

# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-1.5-pro

# =============================================================================
# AWS BEDROCK — LLM_PROVIDER=bedrock
# Install: uv sync --extra bedrock
# =============================================================================

# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# =============================================================================
# AZURE OPENAI — LLM_PROVIDER=azure
# Install: uv sync --extra openai
# =============================================================================

# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# =============================================================================
# OLLAMA (local) — LLM_PROVIDER=ollama
# Install: uv sync --extra ollama
# No API key required — Ollama runs locally.
# =============================================================================

# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# =============================================================================
# LLM GENERATION
# =============================================================================

# Maximum number of tokens the LLM is allowed to generate per call.
# Default: 4096
MAX_TOKENS=4096

# =============================================================================
# MEMORY BACKEND
# =============================================================================

# Which persistence backend to use for LangGraph checkpointing.
# Allowed values: sqlite | redis | postgres
# Default: sqlite (no extra infrastructure required)
MEMORY_BACKEND=sqlite

# Path to the SQLite database file.
# Used when MEMORY_BACKEND=sqlite.
# Default: ./data/agent_memory.db
SQLITE_PATH=./data/agent_memory.db

# Redis connection URL.
# Required only when MEMORY_BACKEND=redis.
# Format: redis://[username:password@]host[:port][/db]
# REDIS_URL=redis://localhost:6379/0

# PostgreSQL connection URL.
# Required only when MEMORY_BACKEND=postgres.
# Install: uv sync --extra postgres
# Format: postgresql+psycopg://user:password@host:port/dbname
# POSTGRES_URL=postgresql+psycopg://user:pass@localhost:5432/langgraph

# =============================================================================
# API SERVER
# =============================================================================

# Host address the uvicorn server binds to.
# Default: 0.0.0.0
API_HOST=0.0.0.0

# TCP port the API server listens on.
# Default: 8000
API_PORT=8000

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Python logging level.
# Allowed values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# OpenTelemetry tracing (optional — install: uv sync --extra observability)
# Set to "true" to enable OTel span export to the OTLP endpoint.
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# THREAD POOL
# =============================================================================

# Size of the ThreadPoolExecutor for blocking agent calls.
# Increase for higher concurrency with slower LLM providers.
# Default: 4
THREAD_POOL_MAX_WORKERS=4

# =============================================================================
# STREAMING (SSE)
# =============================================================================

# Maximum wall-clock seconds allowed for a POST /run/stream pipeline run.
# Increase this for complex queries on slower LLM providers.
# Default: 120
STREAM_TIMEOUT_SECONDS=120

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================

# Allowed values: development | staging | production
# Default: development
ENVIRONMENT=development

# =============================================================================
# SEARCH PROVIDER
# =============================================================================

# Which search backend to use for the web_search tool.
# Options: mock (default), tavily, serpapi
SEARCH_PROVIDER=mock

# Required when SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=your-tavily-api-key-here

# Required when SEARCH_PROVIDER=serpapi
# SERPAPI_API_KEY=your-serpapi-api-key-here

# =============================================================================
# CONNECTORS — Optional retrieval layer (ResearchAnalysisPack only)
# =============================================================================

# When true, the API injects a connector into research_analysis pack runs
# (POST /run, POST /packs/research_analysis/run, and stream variants).
CONNECTOR_ENABLED=false
CONNECTOR_ID=example_memory
# CONNECTOR_ID=http requires CONNECTOR_HTTP_URL (GET with ?q=...&limit=...)
# CONNECTOR_HTTP_URL=https://your-search-api.example.com/retrieve
# CONNECTOR_ID=rag requires RAG_ENABLED=true and: uv sync --extra rag

# =============================================================================
# RAG — Vector Store Integration
# =============================================================================

# RAG (Retrieval-Augmented Generation) via a vector store.
# NOTE: Setting RAG_ENABLED=true currently has no effect on agent behavior.
# The vectorstore infrastructure is in place but not yet wired to agents.
# Full RAG integration is planned for v0.4.0.
RAG_ENABLED=false

# =============================================================================
# COST TRACKING
# =============================================================================

# Max USD per agent per run. Empty = no limit.
# Example: PACK_DEFAULT_BUDGET_USD=0.50
PACK_DEFAULT_BUDGET_USD=

# Optional: path to custom JSON pricing table (see core/cost.py for format).
# LLM_COST_TABLE_PATH=

# =============================================================================
# SECURITY
# =============================================================================

# API Authentication (optional — leave empty to disable)
# API_KEY=

# CORS — comma-separated list of allowed origins
# Leave empty for development (disables credentials enforcement)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Rate limiter backend.
# Allowed values: memory (default, per-process) | redis (shared across replicas)
# When using redis, REDIS_URL must be set above.
RATE_LIMIT_BACKEND=memory
